# ── Copy to .env and fill in your values ──────────────────────────────────────
# NEVER commit .env to source control.

# ── GCP Project ───────────────────────────────────────────────────────────────
PROJECT_ID=my-gcp-project
REGION=us-central1

# ── Resource names ────────────────────────────────────────────────────────────
SERVICE_NAME=langfuse
ARTIFACT_REGISTRY_REPO=langfuse
# GCS bucket that stores WAL segments and base backups
GCS_WAL_BUCKET=my-project-langfuse-wal
# Service account that Cloud Run will run as
SERVICE_ACCOUNT_NAME=langfuse-sa

# ── Secrets (generate with: openssl rand -hex 32) ─────────────────────────────
NEXTAUTH_SECRET=REPLACE_ME
SALT=REPLACE_ME
ENCRYPTION_KEY=REPLACE_ME
POSTGRES_PASSWORD=REPLACE_ME
# ClickHouse `default` user password — required by Langfuse v3+
CLICKHOUSE_PASSWORD=REPLACE_ME

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=langfuse
POSTGRES_DB=langfuse

# ── Derived values (written automatically by setup scripts) ───────────────────
# DATABASE_URL is computed and written by 01-gcp-resources.plain-env.sh
# DATABASE_URL=postgresql://langfuse:PASSWORD@127.0.0.1:5432/langfuse

# GCS HMAC keys for S3-compatible blob storage (written by 01-gcp-resources*.sh)
# GCS_HMAC_ACCESS_KEY=
# GCS_HMAC_SECRET_KEY=

# Cloud Run service hostname — fill in after first deploy, then redeploy
# SERVICE_URL=abc123-uc.a.run.app
