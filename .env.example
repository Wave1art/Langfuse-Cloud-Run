# ── Copy to .env and fill in your values ──────────────────────────────────────
# NEVER commit .env to source control.

# ── GCP Project ───────────────────────────────────────────────────────────────
PROJECT_ID=my-gcp-project
REGION=us-central1

# ── Resource names ────────────────────────────────────────────────────────────
SERVICE_NAME=langfuse
ARTIFACT_REGISTRY_REPO=langfuse
# GCS bucket that stores WAL segments and base backups
GCS_WAL_BUCKET=my-project-langfuse-wal
# Service account that Cloud Run will run as
SERVICE_ACCOUNT_NAME=langfuse-sa

# ── Secrets (generate with: openssl rand -hex 32) ─────────────────────────────
# Stored in Secret Manager by setup/01-gcp-resources.sh
NEXTAUTH_SECRET=REPLACE_ME
SALT=REPLACE_ME
ENCRYPTION_KEY=REPLACE_ME
POSTGRES_PASSWORD=REPLACE_ME

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=langfuse
POSTGRES_DB=langfuse

# ── Derived values (computed automatically in scripts) ─────────────────────────
# IMAGE_BASE=${REGION}-docker.pkg.dev/${PROJECT_ID}/${ARTIFACT_REGISTRY_REPO}
# SERVICE_URL=  (filled in by 03-deploy.sh after first deploy)
